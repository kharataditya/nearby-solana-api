# Base58-encoded private key of the platform wallet (used for signing txs)
PRIVATE_KEY=

# Solana program ID (your deployed Anchor contract)
PROGRAM_ID=CvqzzBzjGeXQoWjuwtSmWSipWFtum3rzWBq7wtAEpX9x

# Solana RPC endpoint
RPC_URL=https://api.devnet.solana.com

# Server port
PORT=3000

# Platform wallet public key (receives the 20% platform fee)
PLATFORM_WALLET=
